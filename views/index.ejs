    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <style>
        /* ===== CUSTOM RESPONSIVE STYLES ===== */

        /* Category Grid */
        .category-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1.5rem;
        }

        .category-card {
            position: relative;
            overflow: hidden;
            border-radius: 0.5rem;
        }

        .category-card img {
            width: 100%;
            height: auto;
            aspect-ratio: 3/4;
            object-fit: cover;
            transition: transform 0.3s;
        }

        .category-card:hover img {
            transform: scale(1.03);
        }

        .category-label {
            position: absolute;
            bottom: 1rem;
            left: 1rem;
            background: rgba(255, 255, 255, 0.9);
            padding: 0.25rem 1rem;
            border-radius: 2rem;
            font-weight: 500;
            font-size: 0.9rem;
        }

        @media (max-width: 768px) {
            .category-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 1rem;
            }
        }

        /* Product Cards */
        .product-card img {
            width: 100%;
            height: auto;
            aspect-ratio: 2/3;
            object-fit: cover;
            border-radius: 0.5rem;
        }

        /* For best seller section images that had fixed classes */
        .fixed-image-container img {
            width: 100%;
            height: auto;
            aspect-ratio: 2/3;
            object-fit: cover;
        }

        /* Cart Sidebar (checkbox hack) */
        #toggle-cart {
            display: none;
        }

        .cart-overlay {
            position: fixed;
            top: 0;
            right: -100%;
            width: 350px;
            max-width: 90vw;
            height: 100vh;
            background: white;
            box-shadow: -2px 0 10px rgba(0, 0, 0, 0.1);
            z-index: 1050;
            transition: right 0.3s ease-in-out;
            overflow-y: auto;
        }

        .backdrop {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            z-index: 1040;
            display: none;
        }

        #toggle-cart:checked~.cart-overlay {
            right: 0;
        }

        #toggle-cart:checked~.backdrop {
            display: block;
        }

        /* Newsletter Modal (custom) */
        #popupModal {
            display: none;
            /* hidden by default */
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            z-index: 1060;
            align-items: center;
            justify-content: center;
        }

        #popupModal .modal-content {
            background: white;
            max-width: 400px;
            width: 90%;
            border-radius: 1rem;
            overflow: hidden;
            position: relative;
        }

        #popupModal img {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }

        #popupModal .modal-body {
            padding: 2rem 1.5rem;
            text-align: center;
        }

        #popupModal .close-btn {
            position: absolute;
            top: 10px;
            right: 15px;
            font-size: 1.5rem;
            cursor: pointer;
            z-index: 1;
            background: white;
            width: 30px;
            height: 30px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0.8;
        }

        #popupModal input {
            width: 100%;
            padding: 0.75rem;
            margin: 1rem 0;
            border: 1px solid #ddd;
            border-radius: 2rem;
        }

        #popupModal .update-btn {
            background: black;
            color: white;
            border: none;
            padding: 0.75rem;
            width: 100%;
            border-radius: 2rem;
            font-weight: 600;
        }

        #popupModal .not-interested {
            background: none;
            border: none;
            text-decoration: underline;
            margin-top: 0.5rem;
            color: #666;
        }

        /* Hero Section - mobile height adjustment */
        .hero-section {
            min-height: 500px;
            height: 100vh;
            max-height: 800px;
        }

        @media (max-width: 576px) {
            .hero-section {
                min-height: 400px;
                height: 70vh;
            }
        }

        /* Testimonial product info */
        .product-info {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-top: 1rem;
        }

        .product-info img {
            width: 50px;
            height: 50px;
            object-fit: cover;
            border-radius: 0.25rem;
        }

        /* Ensure all images are responsive */
        img {
            max-width: 100%;
            height: auto;
        }

        /* Footer social buttons */
        .btn-outline-dark.rounded-circle {
            width: 40px;
            height: 40px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0;
        }

        /* Top bar stacking on mobile */
        @media (max-width: 768px) {
            .top-bar .row>div {
                text-align: center !important;
                justify-content: center !important;
                margin-bottom: 0.5rem;
            }
        }

        @media (max-width: 767px) {
            .top-bar {
                display: none;
            }
        }
    </style>
</head>


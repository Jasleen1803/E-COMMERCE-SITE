    <!-- Bootstrap JS and simple cart quantity script -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        /* ===== CART QUANTITY ===== */
        window.changeQuantity = function (amount) {
            let qtySpan = document.getElementById('qty');
            let currentQty = parseInt(qtySpan.innerText);
            currentQty = isNaN(currentQty) ? 1 : currentQty;
            currentQty += amount;
            if (currentQty < 1) currentQty = 1;
            qtySpan.innerText = currentQty;
        };

        /* ===== MODAL CONTROL ===== */
        const modal = document.getElementById('popupModal');

        function openModal() {
            modal.style.display = 'flex';
            document.body.classList.add('modal-open');
        }

        function closeModal() {
            modal.style.display = 'none';
            document.body.classList.remove('modal-open');
        }

        /* show on page load */
        openModal();

        /* close buttons */
        document.getElementById('closeModal22')?.addEventListener('click', closeModal);
        document.querySelector('.not-interested')?.addEventListener('click', closeModal);

        /* click outside to close */
        modal?.addEventListener('click', function (e) {
            if (e.target === modal) closeModal();
        });
    </script>

    <script>
        window.addEventListener("scroll", function () {
            const nav = document.querySelector(".navbar");

            if (window.scrollY > 60) {
                nav.classList.remove("navbar-expanded");
                nav.classList.add("navbar-shrink");
            } else {
                nav.classList.remove("navbar-shrink");
                nav.classList.add("navbar-expanded");
            }
        });
    </script>

    </script>

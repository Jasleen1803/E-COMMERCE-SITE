<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
  <title>VELVET LANE – Shopping Cart</title>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Font Awesome & Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    /* existing cart overlay styles (kept unchanged) */
    #toggle-cart { display: none; }
    .cart-overlay {
      position: fixed; top: 0; right: 0; width: 30%; max-width: 400px; height: 100vh;
      background-color: #fff; z-index: 1050; overflow-y: auto; border-left: 1px solid #ccc;
      transform: translateX(100%); transition: transform 0.3s ease;
    }
    #toggle-cart:checked ~ .cart-overlay { transform: translateX(0); }
    #toggle-cart:checked ~ .backdrop { display: block; }
    .backdrop {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0,0,0,0.5); z-index: 1040; display: none;
    }

    /* responsive top bar stacking (extra polish) */
    @media (max-width: 767px) {
      .top-bar .row > div {
        text-align: center !important;
        justify-content: center !important;
        margin-bottom: 0.5rem;
      }
      .top-bar .col-md-4 {
        flex: 0 0 100%;
        max-width: 100%;
      }
    }

    /* cart page mobile enhancements */
    @media (max-width: 576px) {
      .cart-table thead {
        display: none; /* hide headers, use card-like rows */
      }
      .cart-table tbody tr {
        display: block;
        border: 1px solid #dee2e6;
        border-radius: 12px;
        margin-bottom: 1rem;
        padding: 1rem;
        background: #fff;
      }
      .cart-table tbody td {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border: none;
        padding: 0.5rem 0;
      }
      .cart-table tbody td:before {
        content: attr(data-label);
        font-weight: 600;
        width: 40%;
        color: #2c2c2c;
      }
      .cart-table td[data-label="Product"]:before {
        content: "Product";
      }
      .cart-table td[data-label="Price"]:before {
        content: "Price";
      }
      .cart-table td[data-label="Quantity"]:before {
        content: "Quantity";
      }
      .cart-table td[data-label="Total"]:before {
        content: "Total";
      }
      .cart-table td:last-child:before {
        content: "Action";
      }
      /* align content */
      .cart-table td > div.d-flex {
        width: 60%;
        justify-content: flex-end;
      }
      .cart-table td .btn-group {
        width: auto;
      }
      .btn-group.btn-group-sm .btn {
        padding: 0.25rem 0.5rem;
      }
      .cart-page h2 {
        font-size: 1.75rem;
      }
    }

    /* tablet fine-tuning */
    @media (min-width:577px) and (max-width: 768px) {
      .cart-table td {
        padding: 0.75rem 0.5rem;
      }
    }

    /* progress bar + alert spacing */
    .timer3 {
      font-weight: 600;
      background: #fff3cd;
      padding: 2px 8px;
      border-radius: 20px;
    }

    /* footer / safe payment */
    .safe-payment-icons i {
      font-size: 2rem;
      margin: 0 5px;
    }

    /* remove default btn focus outline */
    .btn:focus { box-shadow: none; }
  </style>
</head>
<body>

<!-- ==================== TOP BAR (fully responsive) ==================== -->
<div class="bg-light py-2 border-bottom top-bar">
  <div class="container-fluid px-3 px-lg-4">
    <div class="row align-items-center justify-content-between g-2">
      <!-- Left: Social Icons -->
      <div class="col-12 col-md-4 d-flex justify-content-center justify-content-md-start gap-2">
        <a href="#" class="text-dark"><i class="bi bi-facebook"></i></a>
        <a href="#" class="text-dark"><i class="bi bi-twitter-x"></i></a>
        <a href="#" class="text-dark"><i class="bi bi-instagram"></i></a>
        <a href="#" class="text-dark"><i class="bi bi-tiktok"></i></a>
        <a href="#" class="text-dark"><i class="bi bi-pinterest"></i></a>
      </div>
      <!-- Center: Promo Text -->
      <div class="col-12 col-md-4 text-center small text-dark fw-semibold">
        <span>Sale discount off 70%</span> &nbsp;&nbsp;
        <span>Time to refresh your style!</span>
      </div>
      <!-- Right: Currency & Language -->
      <div class="col-12 col-md-4 text-center text-md-end d-flex justify-content-center justify-content-md-end gap-3">
        <div class="dropdown">
          <a class="dropdown-toggle text-dark text-decoration-none small" href="#" data-bs-toggle="dropdown">
            <img src="https://flagcdn.com/us.svg" width="20" alt="USA"> USD
          </a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="#">INR</a></li>
            <li><a class="dropdown-item" href="#">EUR</a></li>
          </ul>
        </div>
        <div class="dropdown">
          <a class="dropdown-toggle text-dark text-decoration-none small" href="#" data-bs-toggle="dropdown">
            English
          </a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="#">Hindi</a></li>
            <li><a class="dropdown-item" href="#">French</a></li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ==================== NAVIGATION (responsive) ==================== -->
<nav class="navbar navbar-expand-lg navbar-light bg-white py-2">
  <div class="container-fluid">
    <a class="navbar-brand fw-bold" href="#">VelvetLane</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="mainNavbar">
      <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Home</a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="#">Home 1</a></li>
            <li><a class="dropdown-item" href="#">Home 2</a></li>
          </ul>
        </li>
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Shop</a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="/PRODUCTLIST">All Products</a></li>
            <li><a class="dropdown-item" href="#">Categories</a></li>
          </ul>
        </li>
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Products</a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="/PRODUCTLIST" target="_blank">All Products</a></li>
            <li><a class="dropdown-item" href="#">Single Product</a></li>
          </ul>
        </li>
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Pages</a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="#">About Us</a></li>
            <li><a class="dropdown-item" href="#">Contact</a></li>
          </ul>
        </li>
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Blog</a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="#">Blog List</a></li>
            <li><a class="dropdown-item" href="#">Blog Single</a></li>
          </ul>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="#">Buy now</a>
        </li>
      </ul>
      <!-- Right Icons -->
      <div class="d-flex align-items-center gap-3">
        <a href="#" class="text-dark"><i class="bi bi-search fs-5"></i></a>
        <a href="#" class="text-dark"><i class="bi bi-person fs-5"></i></a>
        <a href="#" class="text-dark"><i class="bi bi-heart fs-5"></i></a>
        <a href="/cart" class="text-dark"><i class="bi bi-bag fs-5"></i></a>
      </div>
    </div>
  </div>
</nav>

<!-- ==================== MAIN CART CONTENT (fully responsive) ==================== -->
<main class="container cart-page my-4 px-3 px-md-4">
  <h2 class="mb-4 fw-semibold">Shopping Cart</h2>

  <!-- timer alert (flex on mobile) -->
  <div class="alert alert-warning d-flex flex-wrap justify-content-between align-items-center gap-2">
    <span>🕒 These products are limited. Checkout within <span id="timer3" class="timer3">10:00</span></span>
  </div>

  <!-- progress & shipping threshold -->
  <div class="progress mb-3" style="height: 8px;">
    <div class="progress-bar bg-dark" role="progressbar" style="width: 40%;" aria-valuenow="40" aria-valuemin="0" aria-valuemax="100"></div>
  </div>
  <p class="mb-4">Buy <strong>$75.00</strong> more to enjoy <strong>Free Shipping</strong></p>

  <!-- cart items – table with mobile card fallback via data-label -->
  <div class="table-responsive">
    <table class="table cart-table align-middle">
      <thead>
        <tr>
          <th>Product</th>
          <th>Price</th>
          <th class="text-center">Quantity</th>
          <th>Total</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <!-- Item 1: T-shirt -->
        <tr>
          <td data-label="Product">
            <div class="d-flex align-items-center">
              <img src="/images/white t-shirt.png" alt="T‑shirt" class="me-3" style="width:70px; height:auto; object-fit:cover; border-radius:6px;">
              <div>
                <p class="mb-0 fw-medium">T‑shirt</p>
                <small class="text-secondary">Light gray</small>
              </div>
            </div>
          </td>
          <td data-label="Price">$25.00</td>
          <td data-label="Quantity" class="text-center">
            <div class="btn-group btn-group-sm" role="group">
              <button class="btn btn-outline-secondary">−</button>
              <button class="btn btn-outline-secondary">1</button>
              <button class="btn btn-outline-secondary">+</button>
            </div>
          </td>
          <td data-label="Total">$25.00</td>
          <td data-label="Action"><a href="#" class="text-danger text-decoration-none small">Remove</a></td>
        </tr>
        <!-- Item 2: Lavender Shirt -->
        <tr>
          <td data-label="Product">
            <div class="d-flex align-items-center">
              <img src="/images/lavender1.webp" alt="Lavender Shirt" class="me-3" style="width:70px; height:auto; object-fit:cover; border-radius:6px;">
              <div>
                <p class="mb-0 fw-medium">Lavender Shirt</p>
                <small class="text-secondary">Lavender</small>
              </div>
            </div>
          </td>
          <td data-label="Price">$40.00</td>
          <td data-label="Quantity" class="text-center">
            <div class="btn-group btn-group-sm" role="group">
              <button class="btn btn-outline-secondary quantity-decrease">−</button>
              <button class="btn btn-outline-secondary quantity-value">1</button>
              <button class="btn btn-outline-secondary quantity-increase">+</button>
            </div>
          </td>
          <td data-label="Total" class="item-total">$40.00</td>
          <td data-label="Action"><a href="#" class="text-danger text-decoration-none small">Remove</a></td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- order notes -->
  <div class="mb-4">
    <label for="orderNotes" class="form-label fw-semibold">Order notes</label>
    <textarea class="form-control" id="orderNotes" rows="2" placeholder="How can we help you?"></textarea>
  </div>

  <!-- gift wrap + extra shipping message (inline on tablet) -->
  <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4">
    <p class="mb-0 fw-semibold">Buy $75.00 more to enjoy Free Shipping</p>
    <div class="form-check">
      <input class="form-check-input" type="checkbox" id="giftWrap">
      <label class="form-check-label" for="giftWrap">Add gift wrap for $5.00</label>
    </div>
  </div>

  <!-- subtotal + terms -->
  <div class="row g-3 justify-content-end">
    <div class="col-12 col-md-6 col-lg-5">
      <div class="d-flex justify-content-between mb-2">
        <span class="fw-semibold">Subtotal:</span>
        <span class="fw-bold">$65.00 USD</span>
      </div>
      <small class="text-muted d-block mb-3">Taxes and shipping calculated at checkout</small>
      <div class="form-check mb-4">
        <input class="form-check-input" type="checkbox" id="termsCheck">
        <label class="form-check-label small" for="termsCheck">
          I agree with the <a href="#" class="text-decoration-underline">terms and conditions</a>
        </label>
      </div>
      <!-- buttons stack on mobile, inline on desktop -->
      <div class="d-flex flex-column flex-sm-row gap-2 justify-content-md-end">
        <a href="/shop" class="btn btn-outline-dark px-4 py-2">Continue Shopping</a>
        <a href="/checkout" class="btn btn-dark px-4 py-2">Check out</a>
      </div>
    </div>
  </div>

  <!-- safe payment section -->
  <div class="text-center mt-5 pt-2 border-top">
    <p class="mb-2 fw-semibold">Guarantee Safe Checkout</p>
    <div class="safe-payment-icons">
      <i class="fab fa-cc-visa fs-1 mx-1"></i>
      <i class="fab fa-cc-mastercard fs-1 mx-1"></i>
      <i class="fab fa-cc-paypal fs-1 mx-1"></i>
    </div>
    <small class="text-muted">Visa • MasterCard • PayPal</small>
  </div>
</main>

<!-- (optional cart overlay from home page, but not used here) -->
<input type="checkbox" id="toggle-cart">
<div class="cart-overlay p-3">…</div>
<div class="backdrop"></div>

<!-- Bootstrap JS bundle -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<!-- timer script (kept as is) -->
<script>
document.addEventListener('DOMContentLoaded', function () {
  let time = 600; // 10 minutes in seconds
  const timerDisplay = document.getElementById('timer3');
  if (timerDisplay) {
    const countdown = setInterval(() => {
      if (time > 0) {
        const minutes = Math.floor(time / 60);
        const seconds = time % 60;
        timerDisplay.textContent = `${minutes}:${seconds.toString().padStart(2, '0')}`;
        time--;
      } else {
        clearInterval(countdown);
        timerDisplay.textContent = "Expired";
      }
    }, 1000);
  }
});
</script>

<!-- optional: remove empty cart overlay if not needed (just placeholder) -->
</body>
</html>
<!-- Bootstrap JS + countdown + quantity step -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // quantity by 6 (as seen in image)
  function changeQty(delta) {
    let qtySpan = document.getElementById('prodQty');
    let current = parseInt(qtySpan.innerText) || 6;
    let newQty = current + delta;
    if (newQty < 6) newQty = 6;      // minimum 6 (as -6 +6 implies)
    if (newQty > 99) newQty = 99;
    qtySpan.innerText = newQty;
  }

  // countdown timer (set to 11 days 15h from now approx)
  function startCountdown() {
    const target = new Date();
    target.setDate(target.getDate() + 11);
    target.setHours(target.getHours() + 15);
    target.setMinutes(target.getMinutes() + 35);
    target.setSeconds(target.getSeconds() + 43); // to show 43 secs initially

    function updateTimer() {
      const now = new Date();
      let diff = target - now;
      if (diff < 0) diff = 0;
      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
      const mins = Math.floor((diff / (1000 * 60)) % 60);
      const secs = Math.floor((diff / 1000) % 60);
      document.getElementById('flashTimer').innerText = 
        `${days}d : ${hours.toString().padStart(2,'0')}h : ${mins.toString().padStart(2,'0')}m : ${secs.toString().padStart(2,'0')}s`;
    }
    updateTimer();
    setInterval(updateTimer, 1000);
  }
  window.onload = startCountdown;
</script>
</body>
</html>